# HiveSense configuration. Copy to .env and fill in. NEVER commit your real .env
# (it is gitignored). Everything here is optional: with no keys set, the system runs
# in deterministic fallback mode (no LLM, no Redis, no Agentverse).

# ---- LLM provider (Gemini is the project default for HiveDoctor + chat + advisor) ----
GEMINI_API_KEY=             # Google AI Studio key (https://aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=       # only needed by the Agentspan server's Gemini provider
# Alternatives / fallbacks (used if set; Gemini takes priority for the agents):
ASI_ONE_API_KEY=           # ASI:One (asi1) for the uAgent reasoning + chat (https://asi1.ai)
ANTHROPIC_API_KEY=         # optional Claude fallback
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
LLM_PROVIDER=              # optional explicit selector (asi1 | gemini | anthropic)

# ---- Orkes Agentspan (durable human-in-the-loop engine for HiveDoctor) ----
AGENTSPAN_LIVE=0           # set to 1 to run treatment runs on the live engine (needs `agentspan server start`)
AGENTSPAN_MODEL=google_gemini/gemini-2.5-flash

# ---- Redis Stack (optional multimodal memory; falls back to data/verdicts.json) ----
USE_REDIS=0                # set to 1 to use Redis Stack (RedisJSON + TimeSeries + RediSearch + Pub/Sub)
REDIS_URL=redis://localhost:6379
REDIS_TIMEOUT=2            # seconds before falling back to the file store

# ---- Fetch.ai / Agentverse (the uAgent fleet + ASI:One discoverability) ----
AGENTVERSE_API_KEY=        # for mailbox / Agentverse registration
MAILBOX=1                  # 1 = connect via Agentverse mailbox; 0 = pure local dev
AGENT_SEED=                # deterministic agent identity seed
AGENT_ENDPOINT=            # public https endpoint (self-hosted mode; overrides mailbox)
AGENT_CONNECT_URL=         # Agentverse connect URL override
AGENT_TYPE=                # coordinator | hive | chat (per the run scripts)

# ---- Server + simulated feed tuning ----
PORT=8000                  # api_server.py port
FEED_INTERVAL=             # seconds between simulated apiary feed ticks
HIVE_PERIOD=               # seconds between each hive agent's reasoning cycle

# ---- Dataset tooling (only for downloading datasets, not for running the demo) ----
ROBOFLOW_API_KEY=
KAGGLE_API_TOKEN=
